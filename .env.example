# ==============================================================
# PERP — Poultry ERP Platform — Root Environment Configuration
# ==============================================================
# Copy this to .env and fill in your values before running.

# --- PostgreSQL ---
POSTGRES_DB=perp_db
POSTGRES_USER=perp_user
POSTGRES_PASSWORD=change_me_strong_password

# --- Redis ---
REDIS_PASSWORD=change_me_redis_pass

# --- Backend App ---
# Database URL (constructed from above)
DATABASE_URL=postgresql+asyncpg://perp_user:change_me_strong_password@db:5432/perp_db
DATABASE_URL_SYNC=postgresql://perp_user:change_me_strong_password@db:5432/perp_db

# Redis URL
REDIS_URL=redis://:change_me_redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_redis_pass@redis:6379/2

# JWT
JWT_SECRET_KEY=change_me_super_long_jwt_secret_min_64_characters_for_hs256_security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=production
APP_NAME=PERP
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Initial Super Admin (seeded on first run)
SEED_ADMIN_EMAIL=admin@perp.local
SEED_ADMIN_PASSWORD=Admin@2025!
SEED_ADMIN_FULL_NAME=System Administrator
