# Farmexa Backend environment example
# Copy this file to .env and update secrets before starting the app.

APP_NAME=Farmexa
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=db
POSTGRES_USER=farmexa_user
POSTGRES_PASSWORD=change_me_securely
POSTGRES_DB=farmexa_db
POSTGRES_PORT=5432

# Optional override database URLs (if set, these take precedence over POSTGRES_* values)
DATABASE_URL=
DATABASE_URL_SYNC=

REDIS_URL=redis://:perp_redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:perp_redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:perp_redis_pass@redis:6379/2
REDIS_PASSWORD=perp_redis_pass

JWT_SECRET_KEY=supersecretjwtkey
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOWED_ORIGINS=http://localhost:3000,http://localhost,http://localhost:5173
PRIMARY_PLATFORM_DOMAIN=farm.arosoftlabs.com
PLATFORM_HOSTS=farm.arosoftlabs.com,farm.arosoftlabs.com,arosoftlabs.com,localhost,127.0.0.1
DEFAULT_TENANT_DOMAIN_SUFFIX=farm.arosoftlabs.com

CLOUDFLARE_ZONE_NAME=arosoftlabs.com
TENANT_DNS_TARGET_TYPE=A
TENANT_DNS_TARGET_VALUE=
TENANT_DNS_PROXIED=True
TENANT_DNS_TTL=1
TENANT_DOMAIN_TARGET_IP=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_RECORD_TYPE=A
ENABLE_CLOUDFLARE_DNS_AUTOMATION=True
DOMAIN_VERIFY_TIMEOUT_SECONDS=5

CERTBOT_BIN=/usr/bin/certbot
CERTBOT_WEBROOT=/var/www/certbot
CERTBOT_EMAIL=admin@example.com
ENABLE_AUTOMATIC_SSL_PROVISIONING=False

PAYMENT_CALLBACK_SECRET=
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENVIRONMENT=production
PESAPAL_IPN_ID=
PESAPAL_IPN_URL=
PESAPAL_CALLBACK_URL=
PESAPAL_CANCELLATION_URL=
CUSTOM_DOMAIN_ANNUAL_PRICE=25.0
CUSTOM_DOMAIN_CURRENCY=USD

SEED_ADMIN_EMAIL=admin@farmexa.local
SEED_ADMIN_PASSWORD=Admin@2026!
SEED_ADMIN_FULL_NAME=Farmexa System Administrator
SEED_DEV_ADMIN_EMAIL=devadmin@farmexa.local
SEED_DEV_ADMIN_PASSWORD=DevAdmin@2026!
SEED_DEV_ADMIN_FULL_NAME=Farmexa Developer Admin
SEED_DEMO_TENANT_ENABLED=False
SEED_DEMO_TENANT_NAME=Farmexa Test Farm
SEED_DEMO_TENANT_SLUG=testfarm
SEED_DEMO_TENANT_ADMIN_EMAIL=tenantadmin@farmexa.local
SEED_DEMO_TENANT_ADMIN_PASSWORD=TenantAdmin@2026!
SEED_DEMO_TENANT_ADMIN_FULL_NAME=Farmexa Tenant Administrator

UPLOAD_DIR=/app/uploads
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@farmexa.local
SMTP_FROM_NAME=Farmexa
SMTP_USE_TLS=True
