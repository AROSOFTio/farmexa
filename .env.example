# =============================================================
# Farmexa ERP Root Environment Configuration
# =============================================================

# PostgreSQL
POSTGRES_DB=farmexa_db
POSTGRES_USER=farmexa_user
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_pass

# Backend app
DATABASE_URL=postgresql+asyncpg://farmexa_user:change_me_strong_password@db:5432/farmexa_db
DATABASE_URL_SYNC=postgresql://farmexa_user:change_me_strong_password@db:5432/farmexa_db

REDIS_URL=redis://:change_me_redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_redis_pass@redis:6379/2

JWT_SECRET_KEY=change_me_super_long_jwt_secret_min_64_characters_for_hs256_security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

APP_ENV=production
APP_NAME=Farmexa
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost:5173
PRIMARY_PLATFORM_DOMAIN=farmexa.arosoft.io
PLATFORM_HOSTS=farmexa.arosoft.io,arosoft.io,localhost,127.0.0.1
DEFAULT_TENANT_DOMAIN_SUFFIX=arosoft.io
CLOUDFLARE_ZONE_NAME=arosoft.io
TENANT_DNS_TARGET_TYPE=A
TENANT_DNS_TARGET_VALUE=
TENANT_DNS_PROXIED=true
TENANT_DNS_TTL=1
TENANT_DOMAIN_TARGET_IP=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_RECORD_TYPE=A
ENABLE_CLOUDFLARE_DNS_AUTOMATION=true
ENABLE_AUTOMATIC_SSL_PROVISIONING=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=farmexa@arosoft.io
SMTP_PASSWORD=
SMTP_FROM_EMAIL=farmexa@arosoft.io
SMTP_FROM_NAME=Farmexa
SMTP_USE_TLS=true

SEED_ADMIN_EMAIL=admin@farmexa.local
SEED_ADMIN_PASSWORD=Admin@2026!
SEED_ADMIN_FULL_NAME=Farmexa System Administrator
SEED_DEV_ADMIN_EMAIL=devadmin@farmexa.local
SEED_DEV_ADMIN_PASSWORD=DevAdmin@2026!
SEED_DEV_ADMIN_FULL_NAME=Farmexa Developer Admin

# Optional login-only tenant/admin seed for staging or manual testing.
# Keep false in production to avoid creating test tenants.
SEED_DEMO_TENANT_ENABLED=false
SEED_DEMO_TENANT_NAME=Farmexa Test Farm
SEED_DEMO_TENANT_SLUG=testfarm
SEED_DEMO_TENANT_ADMIN_EMAIL=tenantadmin@farmexa.local
SEED_DEMO_TENANT_ADMIN_PASSWORD=TenantAdmin@2026!
SEED_DEMO_TENANT_ADMIN_FULL_NAME=Farmexa Tenant Administrator
