# =============================================================
# Farmexa ERP Root Environment Configuration
# =============================================================

# PostgreSQL
POSTGRES_DB=farmexa_db
POSTGRES_USER=farmexa_user
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_pass

# Backend app
DATABASE_URL=postgresql+asyncpg://farmexa_user:change_me_strong_password@db:5432/farmexa_db
DATABASE_URL_SYNC=postgresql://farmexa_user:change_me_strong_password@db:5432/farmexa_db

REDIS_URL=redis://:change_me_redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:change_me_redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_redis_pass@redis:6379/2

JWT_SECRET_KEY=change_me_super_long_jwt_secret_min_64_characters_for_hs256_security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

APP_ENV=production
APP_NAME=Farmexa ERP
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost:5173

SEED_ADMIN_EMAIL=admin@farmexa.local
SEED_ADMIN_PASSWORD=Admin@2026!
SEED_ADMIN_FULL_NAME=Farmexa System Administrator
